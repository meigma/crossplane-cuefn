#Spec bounds replicas to at most 10, so an over-limit XR must fail schema
validation before any resource renders — the same rejection the API server
enforces through the generated XRD.

-- xr.yaml --
apiVersion: platform.meigma.io/v1alpha1
kind: XApp
metadata:
  name: demo
  namespace: default
spec:
  replicas: 99
-- error.txt --
replicas
